{
  "name": "spur-support-backend",
  "version": "1.0.0",
  "description": "Backend for SpurMart AI Customer Support Agent",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "node node_modules/prisma/build/index.js generate && tsc",
    "start": "node node_modules/prisma/build/index.js db push && node dist/src/server.js",
    "test": "vitest run",
    "db:generate": "node node_modules/prisma/build/index.js generate",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "db:deploy": "node node_modules/prisma/build/index.js migrate deploy",
    "postinstall": "node node_modules/prisma/build/index.js generate && tsc"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.4",
    "@prisma/client": "^5.14.0",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "prisma": "^5.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
